---
import type { Post } from "../../../lib/db";
import { coverPalette, deriveCover } from "./cover";

interface Props {
	post: Pick<Post, "title" | "slug" | "tags" | "cover_variant" | "cover_accent">;
	mode?: "feature" | "card" | "masthead" | "stamp";
	label?: string;
	showLabels?: boolean;
}

const {
	post,
	mode = "card",
	label = "Quiet Observatory",
	showLabels = true,
} = Astro.props;
const model = deriveCover(post);
const palette = coverPalette(model.accent);
const style = `--cover-start:${palette.start}; --cover-mid:${palette.mid}; --cover-end:${palette.end}; --cover-line:${palette.line}; --cover-glow:${palette.glow};`;
const contourLines = Array.from({ length: 6 }, (_, index) => {
	const baseline = 24 + index * 14 + (model.seed % 6);
	return {
		d: `M -8 ${baseline} C ${20 + index * 6} ${baseline - 18} ${56 + index * 5} ${baseline + 18} 112 ${baseline - 6} S 188 ${baseline + 12} 224 ${baseline - 2}`,
	};
});
const weatherRings = Array.from({ length: 4 }, (_, index) => ({
	cx: 48 + index * 26,
	cy: 58 + (model.seed % 12),
	r: 16 + index * 11,
}));
const signalBars = Array.from({ length: 5 }, (_, index) => ({
	x: 20 + index * 34,
	y: 28 + ((model.seed + index * 9) % 42),
	height: 64 - index * 6,
}));
const fieldLines = Array.from({ length: 6 }, (_, index) => ({
	y: 26 + index * 16,
}));
const mineralNodes = Array.from({ length: 3 }, (_, index) => ({
	cx: 42 + index * 52,
	cy: 34 + ((model.seed + index * 11) % 46),
	rx: 24 + index * 7,
	ry: 18 + index * 5,
}));
---

<div
	class:list={["v2-cover", `mode-${mode}`, `variant-${model.variant}`]}
	style={style}
	aria-hidden="true"
>
	<div class="cover-base"></div>
	<div class="cover-vignette"></div>
	<div class="cover-grain"></div>

	<svg class="cover-pattern" viewBox="0 0 224 132" preserveAspectRatio="none">
		{model.variant === "topographic" &&
			contourLines.map((line) => (
				<path d={line.d} class="pattern-line" />
			))}

		{model.variant === "horizon" && (
			<>
				<path
					class="pattern-fill horizon-layer horizon-back"
					d="M 0 58 C 32 44 62 72 88 62 S 142 38 182 50 224 68 224 68 V 132 H 0 Z"
				/>
				<path
					class="pattern-fill horizon-layer horizon-mid"
					d="M 0 78 C 28 72 48 94 90 84 S 150 64 182 74 224 90 224 90 V 132 H 0 Z"
				/>
				<path
					class="pattern-fill horizon-layer horizon-front"
					d="M 0 98 C 28 92 58 114 94 104 S 150 84 184 92 224 108 224 108 V 132 H 0 Z"
				/>
				<circle class="pattern-stroke" cx="176" cy="34" r="20" />
			</>
		)}

		{model.variant === "mineral" && (
			<>
				{mineralNodes.map((node) => (
					<ellipse
						cx={node.cx}
						cy={node.cy}
						rx={node.rx}
						ry={node.ry}
						class="pattern-stroke mineral-shape"
					/>
				))}
				<path
					class="pattern-line"
					d="M 14 108 C 58 82 100 126 142 96 S 210 72 234 92"
				/>
			</>
		)}

		{model.variant === "weather" && (
			<>
				{weatherRings.map((ring) => (
					<circle
						cx={ring.cx}
						cy={ring.cy}
						r={ring.r}
						class="pattern-stroke weather-ring"
					/>
				))}
				<path
					class="pattern-line"
					d="M 24 98 C 44 82 72 112 96 96 S 146 82 170 96 204 102 224 92"
				/>
			</>
		)}

		{model.variant === "signal" && (
			<>
				{signalBars.map((bar) => (
					<rect
						x={bar.x}
						y={bar.y}
						width="12"
						height={bar.height}
						rx="6"
						class="pattern-fill signal-bar"
					/>
				))}
				<path class="pattern-line" d="M 20 86 L 204 46" />
			</>
		)}

		{model.variant === "field-note" && (
			<>
				{fieldLines.map((line) => (
					<line
						x1="18"
						x2="206"
						y1={line.y}
						y2={line.y}
						class="pattern-stroke field-line"
					/>
				))}
				<rect x="32" y="28" width="52" height="34" rx="10" class="pattern-stroke" />
				<circle cx="172" cy="84" r="24" class="pattern-stroke" />
			</>
		)}
	</svg>

	{showLabels && (
		<div class="cover-labels">
			<span>{label}</span>
			<span>{model.variantLabel}</span>
		</div>
	)}
</div>

<style>
	.v2-cover {
		position: relative;
		width: 100%;
		max-width: 100%;
		overflow: hidden;
		border-radius: inherit;
		background:
			radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.34), transparent 36%),
			linear-gradient(135deg, var(--cover-start), var(--cover-mid) 52%, var(--cover-end));
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.35),
			inset 0 -40px 80px rgba(17, 19, 22, 0.14);
	}

	.mode-feature {
		aspect-ratio: 1 / 1.1;
		min-height: 24rem;
		border-radius: 2rem;
	}

	.mode-card {
		aspect-ratio: 5 / 4;
		min-height: 12rem;
		border-radius: 1.5rem;
	}

	.mode-masthead {
		aspect-ratio: 16 / 8;
		min-height: 18rem;
		border-radius: 2rem;
	}

	.mode-stamp {
		aspect-ratio: 1 / 1;
		min-height: 6rem;
		border-radius: 1.25rem;
	}

	.cover-base,
	.cover-vignette,
	.cover-grain,
	.cover-pattern,
	.cover-labels {
		position: absolute;
		inset: 0;
	}

	.cover-base::before {
		content: "";
		position: absolute;
		inset: auto auto 14% -12%;
		width: 62%;
		height: 62%;
		border-radius: 50%;
		background: radial-gradient(circle, var(--cover-glow), transparent 72%);
		filter: blur(12px);
	}

	.cover-vignette {
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.18), transparent 28%),
			linear-gradient(180deg, transparent 50%, rgba(17, 19, 22, 0.18));
	}

	.cover-grain {
		opacity: 0.18;
		mix-blend-mode: overlay;
		background-image:
			radial-gradient(circle, rgba(255, 255, 255, 0.9) 0.9px, transparent 1px),
			radial-gradient(circle, rgba(17, 19, 22, 0.32) 0.8px, transparent 1px);
		background-size: 16px 16px, 23px 23px;
		background-position: 0 0, 10px 10px;
	}

	.cover-pattern {
		width: 100%;
		height: 100%;
	}

	.pattern-line,
	.pattern-stroke {
		fill: none;
		stroke: var(--cover-line);
		stroke-width: 1.5;
		vector-effect: non-scaling-stroke;
	}

	.pattern-fill {
		fill: rgba(255, 255, 255, 0.12);
	}

	.horizon-back {
		fill: rgba(255, 255, 255, 0.1);
	}

	.horizon-mid {
		fill: rgba(17, 19, 22, 0.09);
	}

	.horizon-front {
		fill: rgba(17, 19, 22, 0.16);
	}

	.mineral-shape {
		fill: rgba(255, 255, 255, 0.09);
	}

	.signal-bar {
		fill: rgba(255, 255, 255, 0.12);
	}

	.field-line {
		stroke-dasharray: 6 5;
	}

	.cover-labels {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 1rem;
		padding: 1rem 1.1rem;
		font-size: 0.68rem;
		font-weight: 600;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.88);
	}

	.cover-labels span:last-child {
		text-align: right;
	}

	.mode-stamp .cover-labels {
		padding: 0.75rem;
		font-size: 0.58rem;
		gap: 0.45rem;
	}

	.mode-masthead .cover-labels {
		padding: 1.2rem 1.35rem;
	}

	:global(html[data-theme="dark"]) .v2-cover {
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.12),
			inset 0 -60px 120px rgba(0, 0, 0, 0.34);
	}

	@media (max-width: 1024px) {
		.mode-masthead {
			min-height: 16rem;
		}
	}

	@media (max-width: 780px) {
		.mode-feature {
			min-height: 17.5rem;
		}

		.mode-masthead {
			min-height: 12rem;
		}

		.mode-stamp {
			min-height: 4.6rem;
		}
	}
</style>

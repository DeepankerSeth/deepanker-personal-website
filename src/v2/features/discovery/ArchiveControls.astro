---
---

<form id="library-controls" class="library-controls surface-panel" role="search">
	<div class="search-group">
		<label class="sr-label" for="library-search">Search writings</label>
		<div class="search-shell">
			<span class="search-icon" aria-hidden="true">⌕</span>
				<input
					id="library-search"
					class="v2-input"
					type="search"
					name="q"
					placeholder="Search titles, summaries, or tags"
					aria-controls="library-list"
					autocomplete="off"
				/>
		</div>
	</div>

</form>

<style>
	.library-controls {
		display: grid;
		gap: 1.2rem;
		padding: 1.2rem;
	}

	.search-group {
		display: grid;
		gap: 0.5rem;
	}

	.search-shell {
		position: relative;
	}

	.search-icon {
		position: absolute;
		left: 1rem;
		top: 50%;
		transform: translateY(-50%);
		color: var(--color-text-muted);
		pointer-events: none;
	}

	#library-search {
		padding-left: 2.8rem;
	}

	.sr-label {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	@media (max-width: 780px) {
		.library-controls {
			gap: 0.85rem;
			padding: 0.9rem;
			border-radius: 1.4rem;
		}

		.search-group {
			gap: 0.35rem;
		}

		.search-icon {
			left: 0.9rem;
		}

		#library-search {
			padding-left: 2.35rem;
		}
	}
</style>

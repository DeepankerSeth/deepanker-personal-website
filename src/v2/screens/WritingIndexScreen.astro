---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostArtifactCard from "../components/PostArtifactCard.astro";
import ArchiveControls from "../features/discovery/ArchiveControls.astro";
import { publicUrl } from "../../shared/public/routes";
import { SITE_TITLE } from "../../consts";
import type { Post } from "../../lib/db";

interface Props {
	posts: Post[];
}

const { posts } = Astro.props;
---

<BaseLayout
	title={`Writing — ${SITE_TITLE} — Quiet Observatory`}
	description="A field-guide archive of essays."
	canonical={publicUrl("v2", "writing")}
>
	<section class="library-intro fade-rise">
		<div class="section-heading">
			<p class="eyebrow">Library</p>
			<h1>Deepanker Seth's Writings</h1>
			<p>
				I write when a thought has ripened enough to ask for form.
			</p>
		</div>
		<ArchiveControls />
	</section>

	<section class="library-results" data-reveal style="--reveal-delay: 120ms;">
		<div id="library-list" class="library-list">
			{posts.map((post) => (
				<PostArtifactCard post={post} compact={true} />
			))}
		</div>

		<p id="library-empty" class="library-empty" aria-live="polite" hidden>
			No essays matched the current combination. Try widening the search or
			resetting the filters.
		</p>
	</section>
</BaseLayout>

<style>
	.library-intro {
		display: grid;
		gap: 1.8rem;
		padding-top: 2.8rem;
		max-width: var(--max-library-width);
	}

	.library-intro .section-heading {
		gap: 0.95rem;
		margin-bottom: 0;
	}

	.library-intro h1 {
		margin: 0;
		font-family: var(--font-display);
		font-size: clamp(3rem, 7vw, 5rem);
		font-weight: 400;
		line-height: 0.96;
		letter-spacing: -0.04em;
	}

	.library-results {
		display: grid;
		gap: 1.2rem;
		margin-top: 2rem;
		max-width: var(--max-library-width);
	}

	.library-list {
		display: grid;
		gap: 1rem;
	}

	.library-empty {
		margin: 0;
		padding: 1.1rem 1.2rem;
		border-radius: 1.4rem;
		background: var(--color-surface-soft);
		border: 1px solid var(--color-border);
		color: var(--color-text-secondary);
	}

	@media (max-width: 780px) {
		.library-intro {
			gap: 1rem;
			padding-top: 1.7rem;
		}

		.library-intro .section-heading {
			gap: 0.75rem;
		}

		.library-intro h1 {
			font-size: clamp(2.18rem, 10.8vw, 3.3rem);
		}

		.library-intro .section-heading p:last-child {
			font-size: 0.98rem;
			line-height: 1.68;
		}

		.library-results {
			gap: 0.9rem;
			margin-top: 1.1rem;
		}
	}
</style>

<script>
	const initLibraryDiscovery = () => {
		const controls = document.getElementById("library-controls") as HTMLFormElement | null;
		const list = document.getElementById("library-list") as HTMLDivElement | null;
		if (!controls || !list || controls.dataset.bound === "true") return;

		controls.dataset.bound = "true";
		const libraryWindow = window as Window & {
			__quietObservatoryLibraryHistoryHandler?: () => void;
		};

		const searchInput = document.getElementById("library-search") as HTMLInputElement | null;
		const cards = Array.from(list.querySelectorAll<HTMLElement>("[data-post-card]"));
		const empty = document.getElementById("library-empty") as HTMLParagraphElement | null;

		const readState = () => {
			const params = new URLSearchParams(window.location.search);
			return params.get("q") || "";
		};

		const persistState = (q: string) => {
			const params = new URLSearchParams();
			if (q) params.set("q", q);
			const query = params.toString();
			const nextUrl = query ? `${window.location.pathname}?${query}` : window.location.pathname;
			window.history.replaceState({}, "", nextUrl);
		};

		const applyState = (q: string) => {
			if (searchInput) searchInput.value = q;
			persistState(q);

			const queryTerm = q.trim().toLowerCase();

			let visibleCount = 0;
			cards.forEach((card) => {
				const title = card.dataset.title || "";
				const description = card.dataset.description || "";
				const tags = card.dataset.tags || "";
				const matchesQuery =
					!queryTerm ||
					title.toLowerCase().includes(queryTerm) ||
					description.toLowerCase().includes(queryTerm) ||
					tags.toLowerCase().includes(queryTerm);
				
				card.hidden = !matchesQuery;
				if (matchesQuery) visibleCount += 1;
			});

			if (empty) {
				empty.hidden = visibleCount > 0;
			}
		};

		const readFromDom = () => searchInput?.value || "";

		const bindChange = () => applyState(readFromDom());
		searchInput?.addEventListener("input", bindChange);

		const syncFromHistory = () => applyState(readState());
		if (libraryWindow.__quietObservatoryLibraryHistoryHandler) {
			window.removeEventListener(
				"popstate",
				libraryWindow.__quietObservatoryLibraryHistoryHandler
			);
		}
		libraryWindow.__quietObservatoryLibraryHistoryHandler = syncFromHistory;
		window.addEventListener("popstate", syncFromHistory);

		applyState(readState());
	};

	initLibraryDiscovery();
	document.addEventListener("astro:page-load", initLibraryDiscovery);
</script>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostArtifactCard from "../components/PostArtifactCard.astro";
import V2Cover from "../features/covers/V2Cover.astro";
import { estimateReadingTime } from "../../lib/markdown";
import { publicUrl } from "../../shared/public/routes";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import type { Post } from "../../lib/db";

interface Props {
	featured: Post[];
	latest: Post[];
}

const { featured, latest } = Astro.props;
const leadPost = featured[0] ?? latest[0] ?? null;
const recentFive = latest
	.filter((post) => post.id !== leadPost?.id)
	.slice(0, 5);

const formatDate = (value: string) =>
	new Intl.DateTimeFormat("en-US", {
		month: "long",
		day: "numeric",
		year: "numeric",
	}).format(new Date(value));
---

<BaseLayout
	title={`${SITE_TITLE} — Observatory`}
	description={SITE_DESCRIPTION}
	canonical={publicUrl("v1", "home")}
>
	<section class="home-hero fade-rise">
		<div class="hero-copy">
			<p class="eyebrow">
				Observatory
			</p>
			<h1>
				<span id="greeting-text">Hello</span>
			</h1>
			<p class="hero-summary">
				Here I share some writings on topics that capture my attention.
			</p>
			<div class="hero-actions">
				<a class="hero-cta" href={publicUrl("v2", "writing")}>Enter the library</a>
			</div>
		</div>

		{leadPost && (
			<a
				href={publicUrl("v2", "post", leadPost.slug)}
				class="lead-artifact surface-panel interactive-lift"
			>
				<div class="lead-cover lead-cover-feature">
					<V2Cover post={leadPost} mode="feature" label="Lead Essay" />
				</div>
				<div class="lead-cover lead-cover-compact">
					<V2Cover post={leadPost} mode="card" label="Lead Essay" />
				</div>
				<div class="lead-copy">
					<p class="eyebrow">Lead essay</p>
					<h2>{leadPost.title}</h2>
					<p class="lead-description">{leadPost.description}</p>
					<div class="meta-row">
						<span>{formatDate(leadPost.published_at || leadPost.created_at)}</span>
						<span class="meta-separator"></span>
						<span>{estimateReadingTime(leadPost.content)} min read</span>
					</div>
				</div>
			</a>
		)}
	</section>

	{recentFive.length > 0 && (
		<section class="home-section" data-reveal style="--reveal-delay: 160ms;">
			<div class="section-heading section-heading-inline">
				<div>
					<p class="eyebrow">Featured</p>
					<h2>Latest essays.</h2>
				</div>
				<a class="ghost-link" href={publicUrl("v2", "writing")}>
					View the full library
				</a>
			</div>
			<div class="card-stack">
				{recentFive.map((post) => (
					<PostArtifactCard post={post} compact={true} />
				))}
			</div>
		</section>
	)}
</BaseLayout>

<style>
	.home-hero {
		display: grid;
		grid-template-columns: minmax(0, 1.25fr) minmax(15rem, 0.75fr);
		align-items: start;
		gap: 3.5rem;
		padding-top: 3.5rem;
		overflow-x: clip;
	}

	.hero-copy {
		width: 100%;
		max-width: 40rem;
		min-width: 0;
	}

	.hero-copy h1 {
		margin: 1rem 0 1.4rem;
		font-family: var(--font-display);
		font-size: clamp(3.6rem, 8vw, 6.3rem);
		font-weight: 400;
		line-height: 0.94;
		letter-spacing: -0.05em;
	}

	#greeting-text {
		transition: opacity 1.5s ease-in-out;
		will-change: opacity;
	}

	.fade-out {
		opacity: 0;
	}

	.hero-summary {
		max-width: 34rem;
		margin: 0;
		font-size: clamp(1.1rem, 1rem + 0.35vw, 1.34rem);
		line-height: 1.8;
		color: var(--color-text-secondary);
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 1rem;
		margin-top: 2rem;
	}

	.hero-cta {
		display: inline-flex;
		align-items: center;
		padding: 0.92rem 1.3rem;
		border-radius: 999px;
		background: linear-gradient(135deg, var(--color-accent), var(--color-accent-soft));
		color: white;
		font-weight: 600;
		box-shadow: var(--shadow-card);
	}

	.hero-cta:hover {
		color: white;
		filter: brightness(1.03);
	}

	.lead-artifact {
		display: grid;
		gap: 1.2rem;
		padding: 1rem;
		color: inherit;
		text-decoration: none;
		min-width: 0;
	}

	.lead-cover {
		min-width: 0;
	}

	.lead-cover-compact {
		display: none;
	}

	.lead-copy {
		display: grid;
		gap: 0.8rem;
	}

	.lead-copy h2 {
		margin: 0;
		font-family: var(--font-display);
		font-size: clamp(1.6rem, 2.5vw, 2.2rem);
		font-weight: 400;
		line-height: 0.98;
		letter-spacing: -0.04em;
	}

	.lead-description {
		margin: 0;
		color: var(--color-text-secondary);
		line-height: 1.75;
	}

	.home-section {
		margin-top: 4rem;
	}

	.card-stack {
		display: grid;
		gap: 1rem;
	}

	.section-heading-inline {
		grid-template-columns: minmax(0, 1fr) auto;
		align-items: end;
	}

	@media (max-width: 960px) {
		.home-hero {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 1120px) and (min-width: 961px) {
		.home-hero {
			grid-template-columns: minmax(0, 1.1fr) minmax(14rem, 0.75fr);
			gap: 2rem;
		}
	}

	@media (max-width: 780px) {
		.home-hero {
			gap: 1.1rem;
			padding-top: 1.9rem;
		}

		.hero-copy {
			max-width: 28rem;
		}

		.hero-summary {
			max-width: 24.5rem;
		}

		.hero-copy h1 {
			margin: 0.75rem 0 0.9rem;
			font-size: clamp(2.3rem, 9.8vw, 3.25rem);
		}

		.hero-summary {
			font-size: 0.98rem;
			line-height: 1.68;
		}

		.hero-actions {
			gap: 0.75rem;
			margin-top: 1.15rem;
		}

		.hero-cta {
			padding: 0.78rem 1.02rem;
		}

		.lead-artifact {
			padding: 0.95rem;
		}

		.lead-artifact {
			gap: 0.8rem;
		}

		.lead-cover-feature {
			display: none;
		}

		.lead-cover-compact {
			display: block;
		}

		.lead-copy {
			gap: 0.55rem;
		}

		.lead-copy h2 {
			font-size: clamp(1.6rem, 6.8vw, 2.05rem);
		}

		.lead-description {
			line-height: 1.65;
		}

		.home-section {
			margin-top: 3rem;
		}

		.section-heading-inline {
			grid-template-columns: 1fr;
			align-items: start;
		}
	}
</style>

<script>
	const greetings = [
		"Hello",
		"Namaste",
		"Hola",
		"Bonjour",
		"Konnichiwa",
		"Ciao",
		"Nǐ hǎo",
		"Olá",
		"Marhaba",
	];
	let currentIndex = 0;
	let greetingInterval;

	function initGreetingAnimation() {
		const greetingElement = document.getElementById("greeting-text");
		if (!greetingElement) return;

		if (greetingInterval) clearInterval(greetingInterval);

		greetingInterval = setInterval(() => {
			greetingElement.classList.add("fade-out");

			setTimeout(() => {
				currentIndex = (currentIndex + 1) % greetings.length;
				greetingElement.textContent = greetings[currentIndex];
				greetingElement.classList.remove("fade-out");
			}, 1500); // Wait 1.5s for fade-out
		}, 4500); // 1.5s fade out + 1.5s fade in + 1.5s solid sequence
	}

	initGreetingAnimation();
	document.addEventListener("astro:page-load", initGreetingAnimation);
</script>

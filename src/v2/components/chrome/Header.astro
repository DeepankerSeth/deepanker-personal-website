---
import { SITE_TITLE } from "../../../consts";
import { publicUrl } from "../../../shared/public/routes";
import HeaderLink from "./HeaderLink.astro";
import ThemeToggle from "./ThemeToggle.astro";
---

<a class="skip-link" href="#main-content">Skip to content</a>
<header class="v2-site-header">
	<nav class="v2-site-nav" aria-label="Primary">
		<div class="nav-brand-wrap">
			<a href={publicUrl("v2", "home")} class="site-title">
				<span class="site-copy">
					<span class="site-name">{SITE_TITLE}</span>
				</span>
			</a>
		</div>

		<div class="nav-links">
			<HeaderLink href={publicUrl("v2", "home")}>Observatory</HeaderLink>
			<HeaderLink href={publicUrl("v2", "writing")}>Library</HeaderLink>
		</div>

		<div class="nav-toggle-wrap">
			<ThemeToggle />
		</div>
	</nav>
</header>

<style>
	.v2-site-header {
		position: sticky;
		top: 0;
		z-index: 40;
		padding: 1rem 1.4rem 0.25rem;
		pointer-events: none;
	}

	.v2-site-nav {
		pointer-events: auto;
		max-width: var(--max-shell-width);
		margin: 0 auto;
		padding: 0.9rem 1.1rem;
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto auto;
		grid-template-areas: "brand links toggle";
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		background:
			linear-gradient(180deg, var(--color-surface-veil), transparent),
			var(--color-surface-glass);
		backdrop-filter: blur(18px);
		border: 1px solid var(--color-border);
		border-radius: 999px;
		box-shadow:
			0 1.1rem 2.3rem rgba(22, 20, 19, 0.08),
			inset 0 1px 0 rgba(255, 255, 255, 0.32);
	}

	.nav-brand-wrap {
		grid-area: brand;
		min-width: 0;
	}

	.site-title {
		display: inline-flex;
		align-items: center;
		gap: 0.85rem;
		max-width: 100%;
		color: var(--color-text);
		text-decoration: none;
	}

	.site-copy {
		display: inline-flex;
		flex-direction: column;
		gap: 0.1rem;
		min-width: 0;
	}

	.site-name {
		font-family: var(--font-ui);
		font-weight: 600;
		font-size: 0.98rem;
		letter-spacing: -0.02em;
		white-space: nowrap;
	}

	.nav-links {
		grid-area: links;
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		min-width: 0;
	}

	.nav-toggle-wrap {
		grid-area: toggle;
		display: inline-flex;
		justify-self: end;
		flex-shrink: 0;
	}

	@media (max-width: 780px) {
		.v2-site-header {
			padding: 0.82rem 0.92rem 0.18rem;
		}

		.v2-site-nav {
			padding: 0.76rem 0.86rem;
			gap: 0.7rem;
			border-radius: 1.45rem;
		}
	}

	@media (max-width: 720px) {
		.v2-site-header {
			padding: 0.58rem 0.66rem 0.18rem;
		}

		.v2-site-nav {
			grid-template-columns: minmax(0, 1fr) auto;
			grid-template-areas:
				"brand toggle"
				"links links";
			padding: 0.58rem 0.68rem;
			row-gap: 0.48rem;
			column-gap: 0.6rem;
			border-radius: 1.12rem;
			box-shadow:
				0 0.95rem 1.9rem rgba(22, 20, 19, 0.14),
				inset 0 1px 0 rgba(255, 255, 255, 0.3);
		}

		.nav-brand-wrap {
			display: flex;
			align-items: center;
			min-width: 0;
		}

		.site-title {
			gap: 0.58rem;
			min-width: 0;
		}

		.site-name {
			font-size: 0.88rem;
		}

		.nav-links {
			width: 100%;
			display: grid;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 0.38rem;
		}

		.nav-links :global(.v2-header-link) {
			min-width: 0;
			justify-content: center;
		}
	}

	@media (max-width: 480px) {
		.v2-site-header {
			padding: 0.5rem var(--phone-page-gutter) 0.16rem;
		}

		.v2-site-nav {
			padding: 0.52rem 0.6rem;
			row-gap: 0.42rem;
			column-gap: 0.52rem;
			border-radius: 1rem;
			backdrop-filter: blur(20px);
		}

		.site-name {
			font-size: 0.84rem;
		}

		.nav-links {
			gap: 0.32rem;
		}
	}
</style>

---
interface Props {
	href: string;
	subtle?: boolean;
}

const { href, subtle = false } = Astro.props;
const normalizePath = (value: string) => value.replace(/\/+$/, "") || "/";
const pathname = normalizePath(Astro.url.pathname);
const targetPath = normalizePath(href);
const active =
	pathname === targetPath ||
	(targetPath !== "/" && pathname.startsWith(`${targetPath}/`));
---

<a class:list={["v2-header-link", active && "is-active", subtle && "is-subtle"]} href={href}>
	<slot />
</a>

<style>
	.v2-header-link {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		min-width: 0;
		padding: 0.5rem 0.9rem;
		border-radius: 999px;
		color: var(--color-text-secondary);
		font-size: 0.9rem;
		font-weight: 500;
		letter-spacing: 0.01em;
		text-decoration: none;
		transition:
			color 180ms ease,
			background-color 180ms ease,
			border-color 180ms ease,
			transform 180ms ease;
	}

	.v2-header-link:hover {
		color: var(--color-text);
		background: var(--color-surface-elevated);
	}

	.v2-header-link.is-active {
		color: var(--color-text);
		background: var(--color-surface-elevated);
		box-shadow: inset 0 0 0 1px var(--color-border-strong);
	}

	.v2-header-link.is-subtle {
		color: var(--color-text-muted);
	}

	.v2-header-link.is-subtle:hover {
		color: var(--color-text-secondary);
	}

	@media (max-width: 720px) {
		.v2-header-link {
			width: 100%;
			justify-content: center;
			padding: 0.42rem 0.56rem;
			font-size: 0.78rem;
			line-height: 1.15;
			white-space: nowrap;
			overflow: hidden;
			text-overflow: ellipsis;
		}
	}
</style>

---
import type { Post } from "../../lib/db";
import { parseTags } from "../../lib/db";
import { estimateReadingTime } from "../../lib/markdown";
import { publicUrl } from "../../shared/public/routes";
import V2Cover from "../features/covers/V2Cover.astro";

interface Props {
	post: Post;
	href?: string;
	compact?: boolean;
}

const { post, href = publicUrl("v2", "post", post.slug), compact = false } = Astro.props;
const tagList = parseTags(post.tags);
const readingTime = estimateReadingTime(post.content);
const publishedAt = post.published_at || post.created_at;
---

<article
	class:list={["artifact-card surface-panel interactive-lift", compact && "is-compact"]}
	data-post-card
	data-title={post.title.toLowerCase()}
	data-description={post.description.toLowerCase()}
	data-tags={tagList.join("|").toLowerCase()}
	data-reading-time={readingTime}
	data-published={publishedAt}
>
	<a href={href} class="artifact-link">
		<div class="artifact-cover">
			<V2Cover
				post={post}
				mode={compact ? "stamp" : "card"}
				label="Essay Artifact"
				showLabels={false}
			/>
		</div>

		<div class="artifact-body">
			<div class="meta-row">
				<span>{readingTime} min read</span>
			</div>
			<h3>{post.title}</h3>
			{post.description && <p>{post.description}</p>}
			{tagList.length > 0 && (
				<div class="tag-list">
					{tagList.slice(0, compact ? 3 : 4).map((tag) => (
						<span class="tag-pill">{tag}</span>
					))}
				</div>
			)}
		</div>
	</a>
</article>

<style>
	.artifact-card {
		padding: 1rem;
		border-radius: 1.8rem;
	}

	.artifact-link {
		display: grid;
		grid-template-columns: minmax(10rem, 15rem) minmax(0, 1fr);
		align-items: stretch;
		gap: 1.2rem;
		color: inherit;
		text-decoration: none;
	}

	.artifact-cover {
		height: 100%;
	}

	.artifact-body {
		display: grid;
		align-content: center;
		gap: 0.85rem;
		padding: 0.3rem 0;
		min-width: 0;
	}

	.artifact-body h3 {
		margin: 0;
		font-family: var(--font-display);
		font-weight: 400;
		font-size: clamp(1.5rem, 2vw, 2rem);
		line-height: 1.02;
		letter-spacing: -0.03em;
	}

	.artifact-body p {
		margin: 0;
		color: var(--color-text-secondary);
		line-height: 1.7;
	}

	.artifact-card:hover h3 {
		color: var(--color-accent);
	}

	.artifact-link:focus-visible {
		outline: none;
	}

	.artifact-card.is-compact .artifact-link {
		grid-template-columns: 6.3rem minmax(0, 1fr);
		gap: 1rem;
	}

	.artifact-card.is-compact .artifact-body h3 {
		font-size: clamp(1.35rem, 2vw, 1.7rem);
	}

	.artifact-card.is-compact .artifact-body p {
		font-size: 0.97rem;
	}

	@media (max-width: 780px) {
		.artifact-link {
			grid-template-columns: 1fr;
		}

		.artifact-card.is-compact .artifact-link {
			grid-template-columns: clamp(4.7rem, 23vw, 5.15rem) minmax(0, 1fr);
			align-items: start;
			gap: 0.78rem;
		}

		.artifact-card.is-compact {
			padding: 0.82rem 0.85rem;
		}

		.artifact-card.is-compact .artifact-body {
			align-content: start;
			gap: 0.45rem;
		}

		.artifact-card.is-compact .meta-row {
			gap: 0.38rem;
			font-size: 0.75rem;
			line-height: 1.4;
		}

		.artifact-card.is-compact .artifact-body h3 {
			display: -webkit-box;
			font-size: clamp(1.14rem, 5.6vw, 1.34rem);
			line-height: 1.05;
			-webkit-box-orient: vertical;
			-webkit-line-clamp: 2;
			overflow: hidden;
		}

		.artifact-card.is-compact .artifact-body p {
			display: -webkit-box;
			font-size: 0.9rem;
			line-height: 1.5;
			-webkit-box-orient: vertical;
			-webkit-line-clamp: 2;
			overflow: hidden;
		}

		.artifact-card.is-compact .tag-list {
			gap: 0.35rem;
		}
	}
</style>

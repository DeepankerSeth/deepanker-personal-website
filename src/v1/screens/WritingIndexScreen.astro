---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import SearchBar from '../components/SearchBar.astro';
import TagFilter from '../components/TagFilter.astro';
import type { Post } from '../../lib/db';

interface Props {
	posts: Post[];
	tags: string[];
}

const { posts, tags } = Astro.props;
---

<BaseLayout title="Writing — Deepanker Seth" description="Essays and long-form writings.">
	<section class="writing-header">
		<h1>Writing</h1>
		<p class="writing-subtitle">Essays, reflections, and long-form explorations.</p>
	</section>

	<div class="writing-filters">
		<SearchBar />
		<TagFilter tags={tags} />
	</div>

	<section class="post-list">
		{posts.map((post) => (
			<PostCard
				title={post.title}
				slug={post.slug}
				description={post.description}
				pubDate={post.published_at || post.created_at}
				tags={post.tags}
				content={post.content}
			/>
		))}
	</section>

	<p id="no-results" class="no-results" style="display: none;">
		No writings found matching your search.
	</p>

	{posts.length === 0 && (
		<p class="empty-state">No writings published yet. Check back soon.</p>
	)}
</BaseLayout>

<style>
	.writing-header {
		padding: var(--space-12) 0 var(--space-6);
		max-width: var(--content-width);
	}

	.writing-header h1 {
		font-size: var(--text-4xl);
		letter-spacing: -0.03em;
		margin-bottom: var(--space-2);
	}

	.writing-subtitle {
		font-size: var(--text-lg);
		color: var(--color-text-secondary);
		font-family: var(--font-serif);
	}

	.writing-filters {
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
		max-width: var(--content-width);
		margin-bottom: var(--space-4);
		padding-bottom: var(--space-6);
		border-bottom: 1px solid var(--color-border);
	}

	.post-list {
		max-width: var(--content-width);
	}

	.no-results, .empty-state {
		max-width: var(--content-width);
		color: var(--color-text-muted);
		font-size: var(--text-base);
		padding: var(--space-8) 0;
		text-align: center;
	}

	@media (max-width: 768px) {
		.writing-header {
			padding: var(--space-8) 0 var(--space-4);
		}

		.writing-header h1 {
			font-size: var(--text-3xl);
		}
	}
</style>

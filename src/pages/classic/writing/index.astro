---
import { getAllPublishedPosts, getUniqueTags } from "../../../lib/db";
import WritingIndexScreen from "../../../v1/screens/WritingIndexScreen.astro";

const db = Astro.locals.runtime.env.DB;
const posts = await getAllPublishedPosts(db);
const tags = await getUniqueTags(db);
---

<WritingIndexScreen posts={posts} tags={tags} />

---
import { getAllPublishedPosts, getFeaturedPosts } from "../../lib/db";
import HomeScreen from "../../v2/screens/HomeScreen.astro";

const db = Astro.locals.runtime.env.DB;
const featured = await getFeaturedPosts(db);
const latest = await getAllPublishedPosts(db);
---

<HomeScreen featured={featured} latest={latest} />

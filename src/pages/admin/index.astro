---
import AdminLayout from '../../layouts/AdminLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { getAllPosts } from '../../lib/db';

const db = Astro.locals.runtime.env.DB;
const posts = await getAllPosts(db);
---

<AdminLayout title="Posts">
	<div class="admin-top">
		<h1>Posts</h1>
		<a href="/admin/posts/new" class="btn btn-primary">+ New Post</a>
	</div>

	{posts.length === 0 ? (
		<div class="empty-state">
			<p>No posts yet.</p>
			<a href="/admin/posts/new" class="btn btn-primary">Create your first post</a>
		</div>
	) : (
		<div class="posts-table">
			<table>
				<thead>
					<tr>
						<th>Title</th>
						<th>Status</th>
						<th>Date</th>
						<th>Actions</th>
					</tr>
				</thead>
				<tbody>
					{posts.map((post) => (
						<tr>
							<td>
								<a href={`/admin/posts/${post.id}/edit`} class="post-title-link">
									{post.title}
								</a>
								{post.featured === 1 && <span class="featured-star" title="Featured">★</span>}
							</td>
							<td>
								<span class={`badge badge-${post.status}`}>
									{post.status}
								</span>
							</td>
							<td class="date-cell">
								<FormattedDate date={new Date(post.updated_at)} />
							</td>
							<td class="actions-cell">
								<a href={`/admin/posts/${post.id}/edit`} class="btn btn-sm">Edit</a>
								<a href={`/admin/posts/${post.id}/preview`} class="btn btn-sm">Preview</a>
								<button class="btn btn-sm btn-danger delete-btn" data-id={post.id} data-title={post.title}>Delete</button>
							</td>
						</tr>
					))}
				</tbody>
			</table>
		</div>
	)}
</AdminLayout>

<script>
	document.querySelectorAll('.delete-btn').forEach((btn) => {
		btn.addEventListener('click', async () => {
			const id = (btn as HTMLElement).dataset.id;
			const title = (btn as HTMLElement).dataset.title;
			if (!confirm(`Delete "${title}"? This cannot be undone.`)) return;

			const res = await fetch(`/api/posts/${id}`, { method: 'DELETE' });
			if (res.ok) {
				window.location.reload();
			} else {
				alert('Failed to delete post');
			}
		});
	});
</script>

<style>
	.admin-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: var(--space-8);
	}

	.admin-top h1 {
		font-size: var(--text-2xl);
	}

	.posts-table {
		overflow-x: auto;
	}

	table {
		width: 100%;
		border-collapse: collapse;
	}

	th {
		text-align: left;
		font-size: var(--text-xs);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--color-text-muted);
		padding: var(--space-3) var(--space-4);
		border-bottom: 1px solid var(--color-border);
	}

	td {
		padding: var(--space-3) var(--space-4);
		border-bottom: 1px solid var(--color-border-light);
		font-size: var(--text-sm);
		vertical-align: middle;
	}

	.post-title-link {
		font-weight: 500;
		color: var(--color-text);
	}

	.post-title-link:hover {
		color: var(--color-accent);
	}

	.featured-star {
		color: #f59e0b;
		margin-left: var(--space-1);
		font-size: var(--text-sm);
	}

	.date-cell {
		color: var(--color-text-muted);
		white-space: nowrap;
	}

	.actions-cell {
		display: flex;
		gap: var(--space-2);
		white-space: nowrap;
	}

	.empty-state {
		text-align: center;
		padding: var(--space-16) 0;
		color: var(--color-text-muted);
	}

	.empty-state p {
		margin-bottom: var(--space-4);
	}

	@media (max-width: 768px) {
		th:nth-child(3), td:nth-child(3) {
			display: none;
		}
	}
</style>

---
import PostLayout from '../../../../layouts/PostLayout.astro';
import { getPostById } from '../../../../lib/db';

const { id } = Astro.params;
if (!id) return Astro.redirect('/admin');

const db = Astro.locals.runtime.env.DB;
const post = await getPostById(db, id);

if (!post) {
	return new Response('Post not found', { status: 404 });
}
---

<PostLayout
	title={post.title}
	description={post.description}
	pubDate={post.published_at || post.created_at}
	updatedDate={post.updated_at !== post.created_at ? post.updated_at : null}
	tags={post.tags}
	content={post.content}
>
	<div class="preview-banner">
		<span>Preview Mode</span>
		<a href={`/admin/posts/${post.id}/edit`} class="btn btn-sm">← Back to Editor</a>
	</div>
	<Fragment set:html={post.rendered_html} />
</PostLayout>

<style>
	.preview-banner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: var(--space-3) var(--space-4);
		background: #fef3c7;
		border: 1px solid #fcd34d;
		border-radius: var(--radius);
		font-size: var(--text-sm);
		font-weight: 500;
		color: #a16207;
		margin-bottom: var(--space-8);
	}

	:global([data-theme="dark"]) .preview-banner {
		background: #451a03;
		border-color: #92400e;
		color: #fcd34d;
	}
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getFeaturedPosts, getAllPublishedPosts } from '../lib/db';
import { SITE_TITLE, SITE_DESCRIPTION, SITE_AUTHOR } from '../consts';

const db = Astro.locals.runtime.env.DB;
const featured = await getFeaturedPosts(db);
const latest = await getAllPublishedPosts(db);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<section class="hero">
		<h1><span id="greeting-text">Hello</span></h1>
		<p class="hero-tagline">
			Here I share some pieces on topics that capture my attention.
		</p>
		<a href="/writing" class="hero-link">Read all writings →</a>
	</section>

	{featured.length > 0 && (
		<section class="section">
			<h2 class="section-title">Featured</h2>
			<div class="post-list">
				{featured.map((post) => (
					<PostCard
						title={post.title}
						slug={post.slug}
						description={post.description}
						pubDate={post.published_at || post.created_at}
						tags={post.tags}
						content={post.content}
					/>
				))}
			</div>
		</section>
	)}

	{latest.length > 0 && (
		<section class="section">
			<h2 class="section-title">Latest</h2>
			<div class="post-list">
				{latest.slice(0, 5).map((post) => (
					<PostCard
						title={post.title}
						slug={post.slug}
						description={post.description}
						pubDate={post.published_at || post.created_at}
						tags={post.tags}
						content={post.content}
					/>
				))}
			</div>
			{latest.length > 5 && (
				<a href="/writing" class="view-all">View all writings →</a>
			)}
		</section>
	)}
</BaseLayout>

<style>
	#greeting-text {
		transition: opacity 1s ease-in-out;
	}

	.fade-out {
		opacity: 0;
	}

	.hero {
		padding: var(--space-16) 0 var(--space-12);
		max-width: var(--content-width);
	}

	.hero h1 {
		font-size: var(--text-4xl);
		letter-spacing: -0.03em;
		margin-bottom: var(--space-4);
	}

	.hero-tagline {
		font-size: var(--text-xl);
		color: var(--color-text-secondary);
		line-height: 1.6;
		font-family: var(--font-serif);
		margin-bottom: var(--space-6);
	}

	.hero-link {
		font-size: var(--text-base);
		font-weight: 500;
		color: var(--color-accent);
	}

	.hero-link:hover {
		color: var(--color-accent-hover);
	}

	.section {
		margin-top: var(--space-16);
	}

	.section-title {
		font-size: var(--text-sm);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-text-muted);
		margin-bottom: var(--space-4);
		padding-bottom: var(--space-3);
		border-bottom: 1px solid var(--color-border);
	}

	.post-list {
		max-width: var(--content-width);
	}

	.view-all {
		display: inline-block;
		margin-top: var(--space-6);
		font-size: var(--text-sm);
		font-weight: 500;
		color: var(--color-accent);
	}

	@media (max-width: 768px) {
		.hero {
			padding: var(--space-8) 0 var(--space-6);
		}

		.hero h1 {
			font-size: var(--text-3xl);
		}

		.hero-tagline {
			font-size: var(--text-lg);
		}

		.section {
			margin-top: var(--space-12);
		}
	}
</style>

<script>
	const greetings = ['Hello', 'Namaste', 'Hola', 'Bonjour', 'Konnichiwa', 'Ciao', 'Nǐ hǎo', 'Olá', 'Marhaba'];
	let currentIndex = 0;
	let greetingInterval;

	function initGreetingAnimation() {
		const greetingElement = document.getElementById('greeting-text');
		if (!greetingElement) return;

		if (greetingInterval) clearInterval(greetingInterval);

		greetingInterval = setInterval(() => {
			greetingElement.classList.add('fade-out');

			setTimeout(() => {
				currentIndex = (currentIndex + 1) % greetings.length;
				greetingElement.textContent = greetings[currentIndex];
				greetingElement.classList.remove('fade-out');
			}, 1000); // Wait 1s for fade-out
		}, 3000); // 2s visible + 1s fade-out sequence
	}

	initGreetingAnimation();
	document.addEventListener('astro:page-load', initGreetingAnimation);
</script>
